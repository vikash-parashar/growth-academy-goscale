# Public API (browser + SSR)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Canonical site URL for OG tags, sitemap, and metadata (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: fee banner fallback if API is unreachable (matches backend FEE_INCREASE_*)
NEXT_PUBLIC_FEE_INCREASE_PERCENT=25
NEXT_PUBLIC_FEE_INCREASE_DAYS=10

# Optional: used if backend does not return whatsapp_link on lead create
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# Optional: founder Facebook profile — enables blue Facebook button on Connect + footer
# NEXT_PUBLIC_FOUNDER_FACEBOOK_URL=https://www.facebook.com/your.profile

# Optional: YouTube Data API v3 key (server-only). Enables live comment threads on /podcast.
# Paginates top-level comments (commentThreads.list), scores positive sentiment + likes, returns top 20.
# Create in Google Cloud Console → APIs & Services → Credentials; enable "YouTube Data API v3".
YOUTUBE_API_KEY=
