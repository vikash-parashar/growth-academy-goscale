PORT=8080
GIN_MODE=debug

# PostgreSQL (required). Repo-root `docker-compose.yml` provisions user `goscale`, database `gopher_lab`.
# Local Homebrew Postgres example (database must exist): postgres://postgres@localhost:5432/gopher_lab?sslmode=disable
# Verify: `go run ./cmd/checkdb` from the `backend` folder.
DATABASE_URL=postgres://goscale:goscale@localhost:5432/gopher_lab?sslmode=disable

JWT_SECRET=replace-with-long-random-string
JWT_EXPIRY=24h

ADMIN_USERNAME=admin
# Dev: plain password ok when GIN_MODE != release. Default dummy login: admin / admin123
ADMIN_PASSWORD=admin123

CORS_ORIGINS=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:8080
UPLOAD_DIR=./uploads

WHATSAPP_BUSINESS_NUMBER=919876543210
DEFAULT_PAYMENT_RUPEES=250000

# Paid consultation booking (/book) — slot grid and fee (INR)
CONSULT_FEE_RUPEES=10000
CONSULT_TIMEZONE=Asia/Kolkata
# Weekdays 1=Mon … 7=Sun
CONSULT_WEEKDAYS=1,2,3,4,5
CONSULT_START_HOUR=10
CONSULT_START_MINUTE=0
CONSULT_END_HOUR=18
CONSULT_END_MINUTE=0
CONSULT_SLOT_MINUTES=30

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ADMIN_ALERT_EMAIL=
FROM_EMAIL=noreply@goscalelabs.com

# Twilio (optional) — SMS + WhatsApp outbound via same Messages API
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 for SMS, e.g. +15551234567
TWILIO_SMS_FROM=
# WhatsApp sandbox / sender, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# Public fee announcement (GET /api/public/announcements)
FEE_INCREASE_PERCENT=25
FEE_INCREASE_DAYS=10
# Optional override; leave empty to use default copy
FEE_INCREASE_MESSAGE=
